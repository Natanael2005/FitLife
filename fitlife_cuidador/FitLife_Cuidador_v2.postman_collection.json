{
  "info": {
    "name": "FitLife — Cuidador (GET + POST)",
    "_postman_id": "519b31bb-78c4-41b6-bc21-4a6dd4b964e0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección para probar el servicio Cuidador. Endpoints GET (inter-servicio, sin token) y POST de prueba.\nVariables requeridas en entorno: baseUrl, userId."
  },
  "item": [
    {
      "name": "GET — automáticos (inter-servicio)",
      "item": [
        {
          "name": "Ejercicios aptos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cuidador/ejercicios-aptos?userId={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cuidador",
                "ejercicios-aptos"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Devuelve ejercicios permitidos para el usuario."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });\npm.test(\"Respuesta es array\", function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
