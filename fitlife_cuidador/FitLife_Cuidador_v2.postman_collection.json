              "mode": "raw",
              "raw": "[\n  {\n    \"id\": \"EX-001\",\n    \"slug\": \"PRESS_BANCA\",\n    \"nombre\": \"Press de banca\",\n    \"categoria\": \"Pecho\",\n    \"contraindicaciones\": [\n      \"PROBLEMAS_CARDIACOS\",\n      \"LESION_HOMBRO\"\n    ],\n    \"nivel\": \"INTERMEDIO\",\n    \"series_recomendadas\": 4,\n    \"repeticiones_recomendadas\": 10\n  },\n  {\n    \"id\": \"EX-002\",\n    \"slug\": \"PLANCHA\",\n    \"nombre\": \"Plancha\",\n    \"categoria\": \"Core\",\n    \"contraindicaciones\": [],\n    \"nivel\": \"PRINCIPIANTE\",\n    \"series_recomendadas\": 3,\n    \"repeticiones_recomendadas\": 30\n  },\n  {\n    \"id\": \"EX-003\",\n    \"slug\": \"CAMINATA_RAPIDA\",\n    \"nombre\": \"Caminata rápida\",\n    \"categoria\": \"Cardio\",\n    \"contraindicaciones\": [],\n    \"nivel\": \"PRINCIPIANTE\"\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });\nconst body = pm.response.json();\npm.test(\"Tiene permitidos/bloqueados\", function () {\n  pm.expect(body).to.have.property(\"permitidos\");\n  pm.expect(body).to.have.property(\"bloqueados\");\n});"
                ]
              }
            }
          ]
        },
