        {
          "name": "Todo aptos (builder)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/cuidador/todo-aptos?userId={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cuidador",
                "todo-aptos"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Devuelve { ejercicios, alimentos } para el builder."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", function () { pm.response.to.have.status(200); });\nconst body = pm.response.json();\npm.test(\"Tiene ejercicios y alimentos\", function () {\n  pm.expect(body).to.have.property(\"ejercicios\");\n  pm.expect(body).to.have.property(\"alimentos\");\n  pm.expect(body.ejercicios).to.be.an('array');\n  pm.expect(body.alimentos).to.be.an('array');\n});"
                ]
              }
            }
          ]
        }
      ]
