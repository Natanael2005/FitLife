{
  "info": {
    "name": "FitLife — Auth & Health",
    "_postman_id": "fitlife-auth-health-1759252003",
    "description": "Colección para probar /api/auth y /api/health con Firebase idToken.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "A) Firebase — Sign In (obtener idToken)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"returnSecureToken\": true\n}"
        },
        "url": {
          "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{apiKey}}",
          "protocol": "https",
          "host": [
            "identitytoolkit",
            "googleapis",
            "com"
          ],
          "path": [
            "v1",
            "accounts:signInWithPassword"
          ],
          "query": [
            {
              "key": "key",
              "value": "{{apiKey}}"
            }
          ]
        },
        "description": "Usa el API Key de Firebase Web. Copia idToken de la respuesta y pégalo en la variable {{idToken}}."
      }
    },
    {
      "name": "B) Auth — register-basic (upsert en BD)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{idToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"gender\": \"femenino\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register-basic",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register-basic"
          ]
        }
      }
    },
    {
      "name": "C) Auth — profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{idToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "profile"
          ]
        }
      }
    },
    {
      "name": "D) Health — options (catálogos)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{idToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/health/options",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health",
            "options"
          ]
        }
      }
    },
    {
      "name": "E) Health — save ficha (PUT /user/:id)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{idToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pesoKg\": 92.5,\n  \"estaturaCm\": 170,\n  \"nivel\": \"PRINCIPIANTE\",\n  \"alergias\": [\n    \"gluten\",\n    \"lacteos\"\n  ],\n  \"condiciones\": [\n    \"lesion_rodilla\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/health/user/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health",
            "user",
            "{{userId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "apiKey",
      "value": ""
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "password",
      "value": ""
    },
    {
      "key": "idToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ]
}